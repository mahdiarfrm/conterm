 pub fn deinit(self: *Metal) void {
+    // The layer is retained by the host view's layer tree and can outlive
+    // this renderer. Clear the display callback so a display pass after
+    // teardown finds null instead of a pointer into freed renderer state.
+    self.layer.setDisplayCallback(null, null);
